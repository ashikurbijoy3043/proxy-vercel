{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(css|js|images|.*\\.(png|jpg|jpeg|gif|ico|pem|webp|html|css|js))$",
      "dest": "/public/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/extract.php",
      "dest": "server.js"
    },
    {
      "src": "/load_udid.php",
      "dest": "server.js"
    },
    {
      "src": "/downloads/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/data/uploads/(.*)",
      "dest": "server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}

{
  "version": 2,
  "routes": [
    {
      "src": "/(app.js|style.css|favicon.png|ios_proxy_banner.png)",
      "continue": true
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/extract.php",
      "dest": "/api/index.js"
    },
    {
      "src": "/load_udid.php",
      "dest": "/api/index.js"
    },
    {
      "src": "/downloads/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/data/uploads/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
